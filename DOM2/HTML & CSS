<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Student Grade Calculator</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f4f6f9;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }
    .container {
      background: #fff;
      padding: 20px;
      border: 2px solid #ccc;
      border-radius: 8px;
      text-align: center;
      width: 300px;
    }
    h1 {
      margin-bottom: 15px;
      color: #333;
    }
    input {
      padding: 8px;
      margin: 10px 0;
      width: 80%;
      border: 1px solid #aaa;
      border-radius: 4px;
    }
    button {
      padding: 10px 15px;
      background: #007bff;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
    }
    button:hover {
      background: #0056b3;
    }
    #results {
      margin-top: 15px;
      font-size: 16px;
      font-weight: bold;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Student Grade Calculator</h1>
    <input type="number" id="scoreInput" placeholder="Enter score (0-100)">
    <br>
    <button id="calcBtn">Calculate Grade</button>
    <div id="results"></div>
  </div>

  <script src="script.js"></script>
</body>
</html>
